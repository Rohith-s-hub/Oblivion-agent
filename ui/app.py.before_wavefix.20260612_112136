                return True
            if arg == "stats":
                stats = get_memory_summary()
                if not stats["exists"]:
                    log.write("[dim]No MEMORY.md yet[/dim]")
                else:
                    log.write(Panel(
                        f"[#00ff9f]Notes:[/#00ff9f]      {stats['notes']}\n"
                        f"[#00ff9f]Categories:[/#00ff9f] {stats['categories']}\n"
                        f"[#00ff9f]Size:[/#00ff9f]       {stats['size_bytes']:,} bytes\n"
                        f"[#00ff9f]Path:[/#00ff9f]       {stats['path']}",
                        title="[#b537f2]MEMORY STATS[/#b537f2]",
                        border_style="#b537f2",
                    ))
                return True
            if arg == "edit":
                p = get_memory_path()
                if not p.exists():
                    p.write_text("# Project Memory\n\n_Notes remembered by Oblivion._\n\n", encoding="utf-8")
                log.write(f"[#00ff9f]Memory file: {p}[/#00ff9f]")
                log.write("[dim]Open it in your editor to manually edit.[/dim]")
                return True
            if arg == "clear":
                p = get_memory_path()
                if p.exists():
                    p.unlink()
                log.write("[#ff006e]Memory cleared.[/#ff006e]")
                return True
            log.write("[#ff006e]Usage: /memory [show|stats|edit|clear][/#ff006e]")
            return True

        if command == "/verify":
            from agent.brain import verify_code as vc
            if not arg:
                log.write("[#ff006e]Usage: /verify <path>[/#ff006e]")
                return True
            result = vc(arg.strip())
            if result["ok"]:
                log.write(Panel(
                    f"[#00ff9f]{result['message']}[/#00ff9f]",
